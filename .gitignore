/target/
*.srs
params/*.bin
params/*.json
# Per-crate params/ dirs (e.g. bridge-prover-lib/params/) — exclude the
# multi-GB *_pk.bin proving keys. *_vk.bin and *_config_params.json are
# small and remain explicitly tracked.
**/params/*_pk.bin
proofs/
logs/
# Orchestrator runtime artefacts (multisig keys, per-event witness
# intermediates). Lives in-repo (not /tmp) so a fresh multisig private
# key never lands in world-readable /tmp. One dir per MODE.
work-shellnet/
work-local/
# Per-run state mirror. Regenerated by bridge-prover-daemon/bridge-verifier-daemon on
# every launch; never belongs in version control.
state/
.DS_Store
# Python orchestrator runtime artefacts
python/**/__pycache__/
python/tvm-cli.conf.json
# tvm-cli also writes a config to whichever CWD it runs in; the test orchestrator
# invokes it from the repo root, leaving this artefact behind.
/tvm-cli.conf.json
